<Window x:Class="SwordDamageUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SwordDamageUI"
        mc:Ignorable="d"
        Title="Sword Damage" Height="175" Width="300">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="33*"/>
      <RowDefinition Height="33*"/>
      <RowDefinition Height="33*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>
    <CheckBox x:Name="Flaming" Content="Flaming" HorizontalAlignment="Center" VerticalAlignment="Center" Checked="Flaming_Checked" Unchecked="Flaming_Unchecked" Height="15" Width="62"/>
    <CheckBox x:Name="Magic" Grid.Column="1" Content="Magic" HorizontalAlignment="Center" VerticalAlignment="Center" Height="15" Width="52" Checked="Magic_Checked" Unchecked="Magic_Unchecked"/>
    <Button Content="Roll for damage" HorizontalAlignment="Left" Margin="20,0,0,0" Grid.Row="1" VerticalAlignment="Center" Grid.ColumnSpan="2" Width="260" Height="21" Click="Button_Click"/>
    <TextBlock x:Name="Damage" HorizontalAlignment="Left" TextAlignment="Center" Margin="20,10,0,0" Grid.Row="2" TextWrapping="Wrap" VerticalAlignment="Top" Grid.ColumnSpan="2" Width="260"><Run Language="pt-br" Text="Damage"/></TextBlock>

  </Grid>
</Window>
